{
  "name": "avgchat",
  "version": "1.0.0",
  "description": "AvgChat - Mobile Messenger Application",
  "private": true,
  "scripts": {
    "start": "node server/index.js",
    "client": "cd client && npx vite --host 0.0.0.0 --port 5173",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm install && npx vite build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "sql.js": "^1.10.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "concurrently": "^8.2.2"
  }
}
